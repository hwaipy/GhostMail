# --- Web UI auth (single user) ---
# Generate hash:
#   node -e "import('bcrypt').then(b=>b.hash(process.argv[1],12).then(console.log))" 'your-password'
WEB_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-long-random-string

# --- IMAP ---
IMAP_HOST=imap.qpqi.group
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=

# --- SMTP ---
SMTP_HOST=smtp.qpqi.group
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- Server ---
PORT=4000
HOST=127.0.0.1
# Allow web origin in dev (Vite default)
CORS_ORIGIN=http://localhost:5173
# When set to "production", server also serves /web/dist as static
NODE_ENV=development
