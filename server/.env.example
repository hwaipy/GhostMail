# Only JWT_SECRET is required. Web password and IMAP/SMTP creds
# are configured from the UI (stored in data/config.json, 0600).
JWT_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=4000
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Where to store data/config.json (relative to working dir).
# DATA_DIR=data
